generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  avatarUrl     String?
  bio           String?
  level         String   @default("unknown")
  targetScore   Float?
  streakCount   Int      @default(0)
  lastActiveDate DateTime?
  createdAt     DateTime @default(now())

  subscriptionPlan   String?  // "free" | "monthly" | "yearly"
  subscriptionStatus String   @default("free") // "free" | "active" | "expired" | "cancelled"
  subscriptionExpiresAt DateTime?

  testResults      TestResult[]
  studyPlans       StudyPlan[]
  practiceAttempts PracticeAttempt[]
  wordHistories    WordHistory[]
  flashcards       Flashcard[]
  achievements     Achievement[]
  lessonProgresses  LessonProgress[]
  certificates      Certificate[]
  writingSubmissions WritingSubmission[]
  listeningAttempts  ListeningAttempt[]
  speakingSubmissions SpeakingSubmission[]
  grammarAttempts     GrammarAttempt[]
  vocabularyAttempts  VocabularyAttempt[]
  highlights          Highlight[]
  mockExams           MockExam[]
  topicMasteries      TopicMastery[]
  videoProgress        VideoProgress[]
  payments            Payment[]
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  plan      String   // "monthly" | "yearly"
  amount    Int
  currency  String   @default("UZS")
  status    String   // "pending" | "success" | "failed" | "refunded"
  provider  String?  // "payme" | "click" — keyinchalik to'ldiriladi
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestResult {
  id       String   @id @default(cuid())
  userId   String
  score    Int
  maxScore Int      @default(0)
  level    String
  date     DateTime @default(now())
  testType String   @default("diagnostic")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyPlan {
  id            String   @id @default(cuid())
  userId        String
  currentLevel  String
  targetScore   Float
  hoursPerWeek  Int
  durationWeeks Int?
  planData      String   @default("{}")
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PracticeAttempt {
  id         String   @id @default(cuid())
  userId     String
  practiceId String
  score      Int
  maxScore   Int       @default(0)
  date       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WordHistory {
  id           String   @id @default(cuid())
  userId       String
  word         String
  contextText  String?
  sourceTitle  String?
  seenAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id              String   @id @default(cuid())
  userId          String
  word            String
  meaning         String?
  translation     String?
  visualIcon      String   @default("📝")
  nextReviewDate  DateTime @default(now())
  repetitionLevel Int      @default(0)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  badgeName String
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lesson {
  id                    String   @id @default(cuid())
  title                 String
  category              String
  durationMin           Int
  isPremium             Boolean
  difficulty            String
  order                 Int
  prerequisiteLessonId  String?
  theoryContent         String
  passageText           String?
  tipsAndTricks         String?
  commonMistakes        String?
  questions             String   @default("[]")
  audioUrl              String?
  videoUrl              String?
  videoDurationSec      Int?
  videoThumbnailUrl     String?
  chartUrl              String?
  transcriptText        String?
  taskVisualType        String?   // "bar_chart" | "line_chart" | "pie_chart" | "process_diagram" | "map" | "table"
  taskChartData         Json?     // dinamik grafiklar uchun (bar/line/pie)
  taskImageUrl          String?   // statik rasm/SVG uchun (process diagram, map)

  prerequisite  Lesson?       @relation("LessonPrerequisite", fields: [prerequisiteLessonId], references: [id])
  dependents    Lesson[]      @relation("LessonPrerequisite")
  progresses    LessonProgress[]
  submissions   WritingSubmission[]
  listeningAttempts ListeningAttempt[]
  speakingSubmissions SpeakingSubmission[]
  grammarAttempts     GrammarAttempt[]
  vocabularyWords     VocabularyWord[]
  vocabularyAttempts  VocabularyAttempt[]
  highlights          Highlight[]
  videoProgress        VideoProgress[]
}

model VideoProgress {
  id            String   @id @default(cuid())
  userId        String
  lessonId      String
  watchedPercent Float   @default(0)
  completed     Boolean  @default(false)
  lastWatchedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model LessonProgress {
  id            String    @id @default(cuid())
  userId        String
  lessonId      String
  score         Int?
  maxScore      Int?
  completed     Boolean   @default(false)
  bookmarked    Boolean   @default(false)
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  answers       String    @default("[]")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Certificate {
  id         String   @id @default(cuid())
  userId     String
  category   String
  issuedAt   DateTime @default(now())
  pdfUrl     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WritingSubmission {
  id                String   @id @default(cuid())
  userId            String
  lessonId          String
  essayText         String
  wordCount         Int
  taskAchievement   Float?
  coherenceCohesion Float?
  lexicalResource   Float?
  grammaticalRange  Float?
  overallBand       Float?
  feedback          String?
  submittedAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model ListeningAttempt {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  score       Int
  answers     String   @default("[]")
  attemptedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model SpeakingSubmission {
  id                String   @id @default(cuid())
  userId            String
  lessonId          String
  audioUrl          String
  transcriptText    String?
  fluencyCoherence  Float?
  lexicalResource   Float?
  grammaticalRange  Float?
  pronunciation     Float?
  overallBand       Float?
  feedback          String?
  submittedAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model GrammarAttempt {
  id            String   @id @default(cuid())
  userId        String
  lessonId      String
  score         Int
  mistakesByType String   @default("{}")
  attemptedAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model VocabularyWord {
  id              String   @id @default(cuid())
  lessonId        String
  word            String
  meaning         String
  translation     String
  exampleSentence String
  audioUrl        String?
  visualIcon      String   @default("📝")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model VocabularyAttempt {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  score       Int
  missedWords String   @default("[]")
  attemptedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model MockExam {
  id              String   @id @default(cuid())
  userId          String
  status          String   @default("in_progress")
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  listeningScore  Int?
  listeningBand   Float?
  readingScore    Int?
  readingBand     Float?
  writingTask1Band Float?
  writingTask2Band Float?
  writingBand     Float?
  speakingBand    Float?
  overallBand     Float?

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections MockExamSection[]
}

model MockExamSection {
  id           String   @id @default(cuid())
  mockExamId   String
  sectionType  String
  answers      String   @default("{}")
  score        Float?
  bandScore    Float?
  timeSpentSec Int      @default(0)
  feedback     String?
  submittedAt  DateTime @default(now())

  mockExam MockExam @relation(fields: [mockExamId], references: [id], onDelete: Cascade)
}

model TopicMastery {
  id           String   @id @default(cuid())
  userId       String
  skill        String   // "reading", "writing", "listening", "speaking", "grammar", "vocabulary"
  subtopic     String   // e.g. "Passive Voice", "True/False/Not Given", "Matching Headings"
  correctCount Int      @default(0)
  totalCount   Int      @default(0)
  masteryLevel Float    @default(0) // 0-1
  lastUpdated  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill, subtopic])
}

model Highlight {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  selectedText String
  startOffset  Int
  endOffset    Int
  color        String   @default("yellow")
  note         String?
  createdAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model SpeakingTopicGroup {
  id          String     @id @default(cuid())
  name        String
  icon        String
  description String
  status      String     @default("coming_soon")
  order       Int
  cueCards    CueCard[]
}

model CueCard {
  id           String   @id @default(cuid())
  topicGroupId String
  title        String
  cuePoints    String   @default("[]") // JSON array of strings

  topicGroup SpeakingTopicGroup @relation(fields: [topicGroupId], references: [id], onDelete: Cascade)
}
